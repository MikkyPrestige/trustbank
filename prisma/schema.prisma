generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---

enum UserRole {
  CLIENT
  ADMIN
  SUPER_ADMIN
  SUPPORT
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  FROZEN
}

enum TransactionType {
  TRANSFER
  DEPOSIT
  WITHDRAWAL
  FEE
  REFUND
  WIRE                // <--- RENAMED from WIRE_OUT to match your transfer.ts code
  ADJUSTMENT          // <--- NEW: Essential for Admin to fix balances without fake deposits
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  CRYPTO_BUY
  CRYPTO_SELL
  CRYPTO_SEND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
  ON_HOLD            // <--- NEW: Useful if you want to "freeze" a specific transaction later
}

// --- MODELS ---

model User {
  id                String      @id @default(cuid())

  // 1. Auth & Core
  email             String      @unique
  passwordHash      String
  transactionPin    String      @default("1234")
  role              UserRole    @default(CLIENT)
  status            UserStatus  @default(ACTIVE)

  // 2. Personal Info
  fullName          String
  image             String?     // <--- NEW: Profile Picture (Avatar)
  dateOfBirth       DateTime?
  gender            String?
  phone             String?
  occupation        String?
  taxId             String?     // SSN

  // 3. Contact Info
  address           String?
  city              String?
  state             String?
  zipCode           String?
  country           String?

  // 4. Next of Kin
  nokName           String?
  nokEmail          String?
  nokPhone          String?
  nokRelationship   String?
  nokAddress        String?

  // 5. KYC Files
  passportUrl       String?
  idCardUrl         String?
  kycVerified       Boolean     @default(false)

  // 6. Security & Audit
  lastLoginAt       DateTime?
  lastLoginIp       String?     // <--- NEW: Good for security tracking
  failedLoginAttempts Int       @default(0)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // RELATIONS
  accounts          Account[]
  cards             Card[]
  loans             Loan[]
  wireTransfers     WireTransfer[]
  cryptoAssets      CryptoAsset[]
  beneficiaries     Beneficiary[]
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountNumber     String    @unique
  accountName       String
  routingNumber     String?   // <--- NEW: Makes the bank look "real" (e.g. ACH Routing)
  type              String    @default("SAVINGS")
  status            String    @default("ACTIVE")

  availableBalance  Decimal   @default(0.00) @db.Decimal(19, 4)
  heldBalance       Decimal   @default(0.00) @db.Decimal(19, 4) // <--- NEW: Allows freezing specific funds while keeping account active
  currency          String    @default("USD")

  isPrimary         Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  ledgerEntries     LedgerEntry[]
}

model Beneficiary {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountName       String
  accountNumber     String
  bankName          String
  swiftCode         String?
  routingNumber     String?   // <--- NEW: Added for local US transfers

  createdAt         DateTime  @default(now())
}

model LedgerEntry {
  id                String            @id @default(cuid())
  referenceId       String            @unique

  accountId         String
  account           Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)

  amount            Decimal           @db.Decimal(19, 4)
  balanceAfter      Decimal?          @db.Decimal(19, 4) // <--- NEW: CRITICAL for audit trails (What was the balance right after this?)

  type              TransactionType
  direction         String            // DEBIT or CREDIT
  status            TransactionStatus @default(PENDING)

  description       String?
  metadata          Json?             // Stores extra data (e.g., source IP, admin ID who funded it)

  createdAt         DateTime          @default(now())
}

model Card {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String    @default("VISA")
  cardNumber        String    @unique
  cvv               String
  expiryDate        String
  pin               String?

  status            String    @default("ACTIVE")
  isPhysical        Boolean   @default(false)

  spendingLimit     Decimal?  @db.Decimal(19, 4) // <--- NEW: For Card Controls feature

  createdAt         DateTime  @default(now())
}

model WireTransfer {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  bankName          String
  accountNumber     String
  swiftCode         String
  country           String
  amount            Decimal
  currency          String    @default("USD")

  status            String    @default("PENDING_AUTH")
  currentStage      String    @default("TAA")

  // The "Codes" for the offshore transfer flow
  taaCode           String?
  cotCode           String?
  ijyCode           String?
  imfCode           String?   // <--- NEW: Usually goes with COT/TAX codes

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Loan {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount            Decimal   @db.Decimal(19, 4)
  balanceRemaining  Decimal?  @db.Decimal(19, 4) // To track pay-offs
  termMonths        Int
  interestRate      Decimal   @db.Decimal(5, 2)
  monthlyPayment    Decimal   @db.Decimal(19, 4)
  totalRepayment    Decimal   @db.Decimal(19, 4)
  repaidAmount      Decimal   @default(0) @db.Decimal(19, 4)
  nextPaymentDate   DateTime? // <--- NEW: For payment reminders
  reason            String
  status            String    @default("PENDING")
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime @updatedAt
}

model CryptoAsset {
  id           String   @id @default(cuid())
  userId       String
  symbol       String   // "BTC", "ETH"
  quantity     Decimal  @default(0) @db.Decimal(19, 8)
  avgBuyPrice  Decimal  @default(0) @db.Decimal(19, 2) // <--- KEPT THIS
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

model CryptoTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "BUY", "SELL"
  symbol      String   // Changed from 'currency' to match Asset model
  amount      Decimal  @db.Decimal(19, 8)
  priceAtTime Decimal  @db.Decimal(19, 2)
  totalUsd    Decimal  @db.Decimal(19, 2)
  createdAt   DateTime @default(now())
}

model SystemSettings {
  id                String    @id @default(cuid())
  key               String    @unique
  value             String
  description       String?
}