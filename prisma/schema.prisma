  // --- TOP BAR CONFIG ---
  nav_dashboard_label String? @default("My Dashboard")
  nav_dashboard_link  String? @default("/dashboard")
  nav_rates_label     String?  @default("Rates")
  nav_rates_link      String?  @default("/rates")
